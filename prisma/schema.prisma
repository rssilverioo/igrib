generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// ENUMS
// ============================================

enum OrganizationType {
  IGRIB
  SELLER
  BUYER
}

enum RoleType {
  // Igrib Roles
  IGRIB_ADMIN
  IGRIB_ACCOUNT_MANAGER
  IGRIB_HELPER

  // Seller Roles
  SELLER_SUPERADMIN
  SELLER_SELLER
  SELLER_COMPLIANCE

  // Buyer Roles
  BUYER_SUPERADMIN
  BUYER_PURCHASER
  BUYER_FINANCIAL
  BUYER_COMPLIANCE
}

enum MemberStatus {
  PENDING
  ACTIVE
  SUSPENDED
}

enum ProductStatus {
  DRAFT
  PENDING_APPROVAL
  ACTIVE
  INACTIVE
  SOLD_OUT
}

enum NegotiationStatus {
  OPEN
  IN_PROGRESS
  PROPOSAL_SENT
  COUNTER_PROPOSAL
  ACCEPTED
  REJECTED
  CANCELLED
  COMPLETED
  PENDING_VALIDATION
}

enum ContractStatus {
  PENDING_SIGNATURES
  BUYER_SIGNED
  SELLER_SIGNED
  SIGNED
  CANCELLED
}

enum ProposalStatus {
  DRAFT
  SENT
  ACCEPTED
  REJECTED
  COUNTER_PROPOSAL
  EXPIRED
}

enum InviteStatus {
  PENDING
  ACCEPTED
  EXPIRED
  CANCELLED
}

// ============================================
// NEXTAUTH MODELS
// ============================================

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

// ============================================
// CORE MODELS
// ============================================

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String
  cpf          String?  @unique
  phone        String?
  avatarUrl    String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  memberships  OrganizationMember[]
  invitesSent  Invite[]       @relation("InviteSender")
  products     Product[]      @relation("ProductCreator")
  chatMessages ChatMessage[]
  accounts     Account[]
  sessions     Session[]

  approvedContracts    Contract[] @relation("ContractApprover")
  buyerSignedContracts Contract[] @relation("ContractBuyerSigner")
  sellerSignedContracts Contract[] @relation("ContractSellerSigner")

  @@map("users")
}

model Organization {
  id           String           @id @default(cuid())
  name         String
  type         OrganizationType
  cnpj         String           @unique
  phone        String?
  email        String?
  street       String?
  number       String?
  complement   String?
  neighborhood String?
  city         String?
  state        String?
  zipcode      String?
  country      String           @default("BR")
  logoUrl      String?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  members            OrganizationMember[]
  invites            Invite[]
  products           Product[]
  buyerNegotiations  NegotiationRoom[] @relation("BuyerOrg")
  sellerNegotiations NegotiationRoom[] @relation("SellerOrg")
  buyerContracts     Contract[] @relation("ContractBuyer")
  sellerContracts    Contract[] @relation("ContractSeller")

  @@map("organizations")
}

model OrganizationMember {
  id             String       @id @default(cuid())
  organizationId String
  userId         String
  roleType       RoleType
  status         MemberStatus @default(PENDING)
  joinedAt       DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId])
  @@map("organization_members")
}

model Invite {
  id             String       @id @default(cuid())
  email          String
  organizationId String
  roleType       RoleType
  invitedById    String
  status         InviteStatus @default(PENDING)
  token          String       @unique @default(cuid())
  expiresAt      DateTime
  createdAt      DateTime     @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  invitedBy    User         @relation("InviteSender", fields: [invitedById], references: [id])

  @@map("invites")
}

// ============================================
// PRODUCT MODELS
// ============================================

model Product {
  id             String        @id @default(cuid())
  name           String
  description    String
  type           String
  price          Decimal       @db.Decimal(12, 2)
  quantity       Int
  unit           String        @default("sacas")
  status         ProductStatus @default(DRAFT)
  location       String
  specifications Json          @default("{}")
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  createdById    String
  createdBy      User         @relation("ProductCreator", fields: [createdById], references: [id])

  images       ProductImage[]
  favorites    Favorite[]
  negotiations NegotiationRoom[]
  contracts    Contract[]

  @@map("products")
}

model ProductImage {
  id        String   @id @default(cuid())
  productId String
  url       String
  key       String
  order     Int      @default(0)
  createdAt DateTime @default(now())

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("product_images")
}

model Favorite {
  id        String   @id @default(cuid())
  userId    String
  productId String
  createdAt DateTime @default(now())

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@map("favorites")
}

// ============================================
// NEGOTIATION MODELS
// ============================================

model NegotiationRoom {
  id              String            @id @default(cuid())
  buyerOrgId      String
  sellerOrgId     String
  productId       String
  status          NegotiationStatus @default(OPEN)
  deliveryType    String?
  deliveryAddress Json?
  requestedQty    Int?
  deliveryDate    DateTime?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  buyerOrg  Organization @relation("BuyerOrg", fields: [buyerOrgId], references: [id])
  sellerOrg Organization @relation("SellerOrg", fields: [sellerOrgId], references: [id])
  product   Product      @relation(fields: [productId], references: [id])
  messages  ChatMessage[]
  proposals Proposal[]
  contract  Contract?

  @@unique([buyerOrgId, sellerOrgId, productId])
  @@map("negotiation_rooms")
}

model Proposal {
  id                String         @id @default(cuid())
  negotiationRoomId String
  createdByOrgId    String
  status            ProposalStatus @default(DRAFT)
  pricePerUnit      Decimal        @db.Decimal(12, 2)
  quantity          Int
  unit              String         @default("sacas")
  deliveryType      String
  deliveryAddress   Json?
  deliveryDate      DateTime?
  paymentTerms      String?
  notes             String?
  parentProposalId  String?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  negotiationRoom  NegotiationRoom @relation(fields: [negotiationRoomId], references: [id], onDelete: Cascade)
  parentProposal   Proposal?       @relation("CounterProposals", fields: [parentProposalId], references: [id])
  counterProposals Proposal[]      @relation("CounterProposals")
  contract         Contract?

  @@map("proposals")
}

// ============================================
// CHAT MODELS
// ============================================

model ChatMessage {
  id                String   @id @default(cuid())
  negotiationRoomId String
  senderId          String
  content           String
  messageType       String   @default("text")
  createdAt         DateTime @default(now())

  negotiationRoom NegotiationRoom @relation(fields: [negotiationRoomId], references: [id], onDelete: Cascade)
  sender          User            @relation(fields: [senderId], references: [id])

  @@index([negotiationRoomId, createdAt])
  @@map("chat_messages")
}

// ============================================
// CONTRACT MODELS
// ============================================

model Contract {
  id                  String         @id @default(cuid())
  negotiationRoomId   String         @unique
  proposalId          String         @unique
  buyerOrgId          String
  sellerOrgId         String
  productId           String
  pricePerUnit        Decimal        @db.Decimal(12, 2)
  quantity            Int
  unit                String         @default("sacas")
  deliveryType        String
  deliveryAddress     Json?
  deliveryDate        DateTime?
  paymentTerms        String?
  notes               String?
  status              ContractStatus @default(PENDING_SIGNATURES)
  pdfUrl              String?
  pdfKey              String?
  approvedById        String?
  approvedAt          DateTime?
  buyerSignedById     String?
  buyerSignedAt       DateTime?
  sellerSignedById    String?
  sellerSignedAt      DateTime?
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt

  negotiationRoom NegotiationRoom @relation(fields: [negotiationRoomId], references: [id])
  proposal        Proposal        @relation(fields: [proposalId], references: [id])
  buyerOrg        Organization    @relation("ContractBuyer", fields: [buyerOrgId], references: [id])
  sellerOrg       Organization    @relation("ContractSeller", fields: [sellerOrgId], references: [id])
  product         Product         @relation(fields: [productId], references: [id])
  approvedBy      User?           @relation("ContractApprover", fields: [approvedById], references: [id])
  buyerSignedBy   User?           @relation("ContractBuyerSigner", fields: [buyerSignedById], references: [id])
  sellerSignedBy  User?           @relation("ContractSellerSigner", fields: [sellerSignedById], references: [id])

  @@map("contracts")
}
